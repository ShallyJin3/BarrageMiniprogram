<!-- 全屏预览页面 -->
<view class="fullscreen-container" style="background-color: {{bgColor}};">
  <!-- 文字 -->
  <text class="fullscreen-text" style="color: {{textColor}};">{{displayText}}</text>
  
  <!-- 退出全屏按钮 -->
  <view class="exit-btn" bindtap="goBack">
    <text class="exit-icon">✕</text>
  </view>
</view>
