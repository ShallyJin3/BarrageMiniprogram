.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
}

/* 灯牌展示区域 */
.light-display {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  position: relative;
}

.user-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.light-text {
  font-size: 48rpx;
  font-weight: bold;
}

.fullscreen-hint {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background-color: rgba(0, 0, 0, 0.5);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 输入框区域 */
.input-container {
  margin-top: 30rpx;
}

.input-wrapper {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
}

.barrage-input {
  font-size: 28rpx;
}

.placeholder {
  color: #999;
}

/* 字数提示 */
.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  padding-right: 10rpx;
}

/* 遮罩层 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 99;
}

/* 调色板浮窗 */
.color-picker-float {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  z-index: 100;
  display: flex;
  flex-wrap: wrap;
  width: 600rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.color-option {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 10rpx;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.2);
}

/* 设置模块区域 */
.color-settings {
  margin-top: 30rpx;
}

.color-section {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.color-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.color-label {
  font-size: 28rpx;
  color: #333;
}

.color-preview {
  width: 50rpx;
  height: 50rpx;
  border-radius: 10rpx;
  border: 1rpx solid #ddd;
}

.image-preview {
  font-size: 24rpx;
  color: #666;
}

.image-preview.empty {
  color: #999;
}
