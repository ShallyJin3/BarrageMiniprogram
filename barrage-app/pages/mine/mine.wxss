.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #ffffff;
}

.profile-section {
  text-align: center;
  padding: 40rpx 0;
}

.avatar-container {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #852D91, #312A6C);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.level {
  font-size: 26rpx;
  color: #852D91;
  display: block;
  margin-top: 15rpx;
}

.stats-container {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 10rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
}
