.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #ffffff;
  position: relative;
}

.barrage-display {
  width: 100%;
  height: 400rpx;
  background-color: #000000;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  margin-bottom: 40rpx;
  position: relative;
}

.barrage-scroll {
  white-space: nowrap;
  animation: scroll-left linear infinite;
}

.barrage-text {
  font-size: 48rpx;
  color: #ffffff;
}

.fullscreen-hint {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background-color: rgba(0, 0, 0, 0.5);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

@keyframes scroll-left {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(-100%);
  }
}

.input-container {
  width: 100%;
}

.input-wrapper {
  width: 100%;
}

.barrage-input {
  width: 100%;
  height: 100rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #333333;
  caret-color: #D585FF;
  box-sizing: border-box;
}

.placeholder {
  color: #999999;
}

/* 遮罩层 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: transparent;
  z-index: 50;
}

.color-settings {
  margin-top: 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: space-between;
}

.color-section {
  width: calc(50% - 10rpx);
}

.color-btn {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
}

.color-label {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.color-preview {
  width: 50rpx;
  height: 50rpx;
  border-radius: 10rpx;
  border: 2rpx solid #ddd;
}

.speed-preview {
  font-size: 28rpx;
  color: #D585FF;
  font-weight: bold;
}

/* 悬浮调色板 - 底部弹出 */
.color-picker-float {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 30rpx;
  background-color: #ffffff;
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  justify-content: center;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.color-option {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
}

/* 速度设置滑块 */
.speed-display {
  width: 100%;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #D585FF;
  margin-bottom: 20rpx;
}

.speed-slider {
  width: 100%;
}

.speed-labels {
  width: 100%;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}
