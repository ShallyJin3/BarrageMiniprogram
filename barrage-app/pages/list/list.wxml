<view class="container">
  <view class="header">
    <text class="title neon-text">📋 弹幕列表</text>
  </view>

  <view class="list-container">
    <view class="list-item neon-border" wx:for="{{items}}" wx:key="index">
      <view class="item-content">
        <text class="item-text">{{item.text}}</text>
        <text class="item-time">{{item.time}}</text>
      </view>
      <view class="item-effect" style="color: {{item.color}}">{{item.emoji}}</view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{items.length === 0}}">
    <text>🎉 暂无弹幕，快去发送第一条！</text>
  </view>
</view>
