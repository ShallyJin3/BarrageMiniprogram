.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #ffffff;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.list-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.08);
}

.item-content {
  flex: 1;
}

.item-text {
  font-size: 30rpx;
  color: #333333;
  display: block;
}

.item-time {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 10rpx;
}

.item-effect {
  font-size: 40rpx;
}

.empty-tip {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  margin-top: 100rpx;
}
