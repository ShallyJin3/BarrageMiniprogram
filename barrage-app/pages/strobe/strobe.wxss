/* pages/strobe/strobe.wxss */
.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  transition: background-color 0.1s;
}

.container.white {
  background-color: #ffffff;
}

.container.black {
  background-color: #000000;
}

.back-btn {
  margin-top: 60px;
  margin-left: 20px;
  padding: 20rpx 40rpx;
  font-size: 36rpx;
  color: #ffffff;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 10rpx;
}

/* 白色背景时返回按钮用黑色 */
.container.white .back-btn {
  color: #000000;
  background-color: rgba(255, 255, 255, 0.5);
}
