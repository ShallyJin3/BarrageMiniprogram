<view class="container">
  <!-- 第一排卡片 -->
  <view class="card-container">
    <!-- 手持弹幕卡片 -->
    <view class="card" bindtap="goToBarrage">
      <image class="card-icon" src="/images/barrage.png" mode="aspectFit"></image>
      <text class="card-title">滚动弹幕</text>
      <text class="card-desc">滚动字幕Show全场</text>
    </view>

    <!-- 爆闪屏幕卡片 -->
    <view class="card" bindtap="goToStrobe">
      <image class="card-icon" src="/images/strobe.png" mode="aspectFit"></image>
      <text class="card-title">爆闪屏幕</text>
      <text class="card-desc">闪烁特效嗨翻全场</text>
    </view>
  </view>

  <!-- 第二排：表白灯牌 + 手机手灯 -->
  <view class="card-container">
    <!-- 表白灯牌 -->
    <view class="card" bindtap="goToConfession">
      <image class="card-icon" src="/images/confession.png" mode="aspectFit"></image>
      <text class="card-title">表白灯牌</text>
      <text class="card-desc">静态文字展示</text>
    </view>

    <!-- 手机手灯 -->
    <view class="card" bindtap="goToFlashlight">
      <image class="card-icon" src="/images/flashlight.png" mode="aspectFit"></image>
      <text class="card-title">手机手灯</text>
      <text class="card-desc">随节奏变换手灯颜色</text>
    </view>
  </view>
</view>
