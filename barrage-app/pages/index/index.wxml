<view class="container">
  <!-- 两个功能卡片 -->
  <view class="card-container">
    <!-- 手持弹幕卡片 -->
    <view class="card" bindtap="goToBarrage">
      <image class="card-icon" src="/images/barrage.png" mode="aspectFit"></image>
      <text class="card-title">手持弹幕</text>
      <text class="card-desc">滚动字幕Show全场</text>
    </view>

    <!-- 爆闪屏幕卡片 -->
    <view class="card" bindtap="goToStrobe">
      <image class="card-icon" src="/images/strobe.png" mode="aspectFit"></image>
      <text class="card-title">爆闪屏幕</text>
      <text class="card-desc">闪烁特效嗨翻全场</text>
    </view>
  </view>
</view>
