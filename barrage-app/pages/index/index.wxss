.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  display: block;
  color: #ff00ff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #00ffff;
  display: block;
  margin-top: 20rpx;
  text-shadow: 0 0 10px #00ffff;
}

.card-container {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding-top: 40rpx;
}

.card {
  background: linear-gradient(180deg, #8E78FF 0%, #FC7D7B 100%);
  border-radius: 24rpx;
  border: none;
  padding: 0 16rpx;
  width: 320rpx;
  flex-shrink: 0;
  overflow: visible;
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
}

.card-icon {
  width: 200rpx;
  height: 200rpx;
  display: block;
  margin: -30rpx auto 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  text-align: center;
  margin-top: 10rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #ffffff;
  display: block;
  text-align: center;
  margin-top: 8rpx;
  padding-bottom: 20rpx;
}
