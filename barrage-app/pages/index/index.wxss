.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  display: block;
  color: #ff00ff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #00ffff;
  display: block;
  margin-top: 20rpx;
  text-shadow: 0 0 10px #00ffff;
}

.card-container {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding-top: 40rpx;
}

.card {
  background: linear-gradient(180deg, #D585FF 0%, #00FFEE 100%);
  border-radius: 25rpx;
  border: none;
  padding: 0 12rpx;
  width: 285rpx;
  flex-shrink: 0;
  overflow: visible;
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
}

.card-icon {
  width: 193rpx;
  height: 193rpx;
  display: block;
  margin: -25rpx auto 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  text-align: center;
  margin-top: 8rpx;
}

.card-desc {
  font-size: 20rpx;
  color: #333333;
  display: block;
  text-align: center;
  margin-top: 4rpx;
  padding-bottom: 13rpx;
}
